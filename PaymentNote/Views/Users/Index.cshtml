
@{
    ViewBag.Title = "User Data";
}
<style>
    /* Perkecil font dan padding tabel */
    #userTable th, #userTable td {
        font-size: 12px;
        padding: 5px 8px;
        white-space: nowrap;
    }
    /* Perkecil search input di footer */
    #userTable tfoot input {
        font-size: 11px;
        padding: 2px 4px;
        width: 100%;
    }
    /* Paksa sidebar tidak mendorong konten */
    .content-wrapper {
        overflow-x: hidden;
    }
</style>
<section class="content">
    <div class="card">
        <div class="card-header py-2">
            <h3 class="card-title">
                <a class="btn btn-primary btn-sm" href="@Url.Action("Editor", "UserData", new { mode = "Create" })">
                    <i class="fa fa-plus"></i> Create
                </a>
            </h3>
            <div class="card-tools">
                <div class="input-group input-group-sm mr-2" style="width: 180px; display: inline-flex;">
                    <input type="text" id="tableSearch" class="form-control" placeholder="Search..." />
                    <div class="input-group-append">
                        <button type="button" class="btn btn-default">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                </div>
                <button type="button" class="btn btn-tool" data-card-widget="collapse" title="Collapse">
                    <i class="fas fa-minus"></i>
                </button>
                <button type="button" class="btn btn-tool" data-card-widget="remove" title="Remove">
                    <i class="fas fa-times"></i>
                </button>
            </div>
        </div>
        <div class="card-body p-0">
            <table id="userTable" class="table table-striped projects">
                <thead>
                    <tr>
                        <th>Username</th>
                        <th>First Name</th>
                        <th>Department</th>
                        <th>Is Admin</th>
                        <th>Location</th>
                        <th>Last Login</th>
                        <th style="width: 20%; text-align: center"> Action </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach(var item in Model)
            {
                <tr>
                    <td>@item.username</td>
                    <td>@item.first_name</td>
                    <td>@item.Department</td>
                    <td>@(item.isAdmin ? "Yes" : "No")</td>
                    <td>@item.location</td>
                    <td>@item.LastLogin</td>
                    <td class="text-center">
                        <a href="@Url.Action("Editor", "UserData", new { id = item.user_id, mode = "View" })"
                           class="btn btn-info btn-xs" title="View">
                            <i class="fa fa-eye"></i> View
                        </a>
                        <a href="@Url.Action("Editor", "UserData", new { id = item.user_id, mode = "Edit" })"
                           class="btn btn-warning btn-xs" title="Edit">
                            <i class="fa fa-edit"></i> Edit
                        </a>
                        <a href="@Url.Action("Editor", "UserData", new { id = item.user_id, mode = "Delete" })"
                           class="btn btn-danger btn-xs" title="Delete">
                            <i class="fa fa-trash"></i> Delete
                        </a>
                    </td>
                </tr>
            }
               </tbody>
                <tfoot>
                    <tr>
                        <th>Username</th>
                        <th>First Name</th>
                        <th>Department</th>
                        <th>Is Admin</th>
                        <th>Location</th>
                        <th>Last Login</th>
                        <th>Action</th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</section>

<script>
    $(function () {
        $('#userTable tfoot th').each(function () {
            var i = $(this).index();
            if (i != 6) {
                var title = $(this).text().trim();
                $(this).html('<input type="text" placeholder="Search ' + title + '" />');
            }
        });

        var table = $('#userTable').DataTable({
            "responsive": true,
            "lengthChange": true,
            "lengthMenu": [[10, 25, 50, 100, 500, 1000, -1], [10, 25, 50, 100, 500, 1000, "All"]],
            "pageLength": 10,
            "autoWidth": false,
            "paging": true,
            "searching": true,
            "ordering": true,
            "info": true,
            "dom": 'lBrtip',
            "stateSave": false
        })

        table.columns().every(function (i) {
            var that = this;
            if (i < 6) {
                $('input', this.footer()).on('keyup change', function () {
                    if (that.search() !== this.value) {
                        that.search(this.value).draw();
                    }
                });
            }
        });

        $("#tableSearch").on("keyup", function () {
            table.search(this.value).draw();
        });

        @if (TempData["SucessMessage"] != null)
            {
                 <text> toastr.success('@TempData["SuccessMessage"]'); </text>
            }
        @if (TempData["ErrorMessage"] != null)
            {
            <text> toastr.error('@TempData["ErrorMassage"]'); </text>
            }
    });
</script>
