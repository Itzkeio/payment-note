@model global::PaymentNote.ViewModel.OperationalViewModel
@{
    var mode = ViewBag.Mode ?? "Create";
    ViewBag.Title = @mode + " - Operational";
    var readOnly = mode == "View" || mode == "Delete";
}

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

<style>
    .form-horizontal .form-group {
        display: flex;
        align-items: center;
        margin-bottom: 15px;
    }

    .form-horizontal .form-label {
        flex: 0 0 200px;
        font-weight: 600;
        margin-bottom: 0;
        padding-right: 15px;
    }

    .form-horizontal .form-input {
        flex: 1;
        max-width: 450px;
    }

    .readonly-field {
        background-color: #e9ecef !important;
    }

    .detail-table th {
        background-color: #ffc107;
        color: #000;
        font-weight: 600;
    }

    /* ====== Fix ukuran input di modal ====== */
    .modal-body .form-control {
        width: 100% !important;
        max-width: 100% !important;
    }

    .modal-body textarea.form-control {
        min-height: 80px;
        resize: vertical;
    }

    .modal .col-sm-8 {
        flex: 1;
        max-width: none !important;
    }
</style>

<section class="content">
    

    @using (Html.BeginForm("Editor", "Operational", FormMethod.Post, new { id = "operationalForm" }))
    {
        @Html.AntiForgeryToken()
        <input type="hidden" name="mode" value="@mode" />

        <!-- ========== FORM 1: Header ========== -->
        <div class="card card-default">
            <div class="card-body form-horizontal">

                <div class="form-group">
                    <label class="form-label">PO ID</label>
                    <div class="form-input">
                        @if (mode == "Create")
                        {
                            @Html.TextBoxFor(m => m.po_id, new { @class = "form-control readonly-field", @readonly = "readonly", placeholder = "*Auto Generate" })
                        }
                        else
                        {
                            @Html.TextBoxFor(m => m.po_id, new { @class = "form-control readonly-field", @readonly = "readonly" })
                        }
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Company Code <span class="text-danger">*</span></label>
                    <div class="form-input">
                        @if (mode == "View" || mode == "Delete")
                        {
                            @Html.TextBoxFor(m => m.company_code, new { @class = "form-control", @readonly = "readonly" })
                        }
                        else
                        {
                            @Html.DropDownListFor(m => m.company_code, Model.GetCompanyListItem(), "Select Company", new { @class = "form-control select2", id = "companyDropdown" })
                        }
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Currency <span class="text-danger">*</span></label>
                    <div class="form-input">
                        @if (mode == "View" || mode == "Delete")
                        {
                            @Html.TextBoxFor(m => m.currency, new { @class = "form-control", @readonly = "readonly" })
                        }
                        else
                        {
                            @Html.DropDownListFor(m => m.currency, Model.GetCurrencyListItem(), "Select Currency", new { @class = "form-control select2", id = "currencyDropdown" })
                        }
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Currency Rate <span class="text-danger">*</span></label>
                    <div class="form-input">
                        @if (mode == "View" || mode == "Delete")
                        {
                            @Html.TextBoxFor(m => m.currency_rate, new { @class = "form-control", type = "number", @readonly = "readonly" })
                        }
                        else
                        {
                            @Html.TextBoxFor(m => m.currency_rate, new { @class = "form-control", type = "number", placeholder = "Input Currency Rate" })
                        }
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Vendor <span class="text-danger">*</span></label>
                    <div class="form-input">
                        @if (mode == "View" || mode == "Delete")
                        {
                            var vendorDesc = "";
                            if (Model.vendor.HasValue)
                            {
                                var v = Model.VendorList.FirstOrDefault(x => x.vendor_id == Model.vendor.Value);
                                vendorDesc = v?.vendor_desc ?? "";
                            }
                            <input type="text" class="form-control" value="@vendorDesc" readonly />
                            @Html.HiddenFor(m => m.vendor)
                        }
                        else
                        {
                            @Html.DropDownListFor(m => m.vendor, Model.GetVendorListItem(), "Select Vendor", new { @class = "form-control select2", id = "vendorDropdown" })
                        }
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Status <span class="text-danger">*</span></label>
                    <div class="form-input">
                        @if (mode == "Create")
                        {
                            <input type="text" class="form-control readonly-field" value="New" readonly />
                            <input type="hidden" name="status_value" value="New" />
                        }
                        else if (mode == "View" || mode == "Delete")
                        {
                            @Html.DropDownList(
                                "status_value",
                                new SelectList(PaymentNote.ViewModel.OperationalViewModel.GetStatusListItem(), "Value", "Text", ViewBag.CurrentStatus as string ?? ""),
                                "-- Select Status --",
                                new { @class = "form-control select2", id = "status_select", disabled = "disabled" })
                        }
                        else
                        {
                            @Html.DropDownList(
                                "status_value",
                                new SelectList(PaymentNote.ViewModel.OperationalViewModel.GetStatusListItem(), "Value", "Text", ViewBag.CurrentStatus as string ?? ""),
                                "-- Select Status --",
                                new { @class = "form-control select2", id = "status_select" })
                        }
                    </div>
                </div>

                <div class="form-group" style="align-items: flex-start;">
                    <label class="form-label" style="padding-top: 8px;">Remarks</label>
                    <div class="form-input">
                        @if (mode == "View" || mode == "Delete")
                        {
                            @Html.TextAreaFor(m => m.Remarks, new { @class = "form-control", @readonly = "readonly", rows = 3 })
                        }
                        else
                        {
                            @Html.TextAreaFor(m => m.Remarks, new { @class = "form-control", placeholder = "Input Remarks", rows = 3 })
                        }
                    </div>
                </div>

            </div>
        </div>

        <!-- ========== FORM 2: Detail Transaction ========== -->
        <div class="card card-default mt-3">
            <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Detail Transaction</h5>
            </div>
            <div class="card-body">
                @if (!readOnly)
                {
                    <button type="button" class="btn btn-primary btn-sm mb-2" id="btnAddDetail">
                        <i class="fa fa-plus"></i> Add Detail
                    </button>
                }

                <div class="table-responsive">
                    <table class="table table-bordered detail-table" id="detailTable">
                        <thead>
                            <tr>
                                <th style="width:40px">No</th>
                                <th>PO No</th>
                                <th>PO Type</th>
                                <th>PO Date</th>
                                <th>Department</th>
                                <th>Amount DPP</th>
                                <th>Amount VAT</th>
                                <th>Amount Freight</th>
                                <th>Amount Freight VAT</th>
                                <th>Remarks</th>
                                @if (!readOnly)
                                {
                                    <th style="width:100px">Action</th>
                                }
                            </tr>
                        </thead>
                        <tbody id="detailTableBody">
                            @{ int rowIndex = 0; }
                            @if (Model.Details != null && Model.Details.Any())
                            {
                                foreach (var d in Model.Details)
                                {
                                    <tr data-index="@rowIndex">
                                        <td>@(rowIndex + 1)</td>
                                        <td>@d.po_no <input type="hidden" name="Details[@rowIndex].po_no" value="@d.po_no" /></td>
                                        <td>@d.po_type <input type="hidden" name="Details[@rowIndex].po_type" value="@d.po_type" /></td>
                                        <td>@(d.po_date?.ToString("yyyy-MM-dd")) <input type="hidden" name="Details[@rowIndex].po_date" value="@(d.po_date?.ToString("yyyy-MM-dd"))" /></td>
                                        <td>@d.po_dept <input type="hidden" name="Details[@rowIndex].po_dept" value="@d.po_dept" /></td>
                                        <td>@d.amount_dpp <input type="hidden" name="Details[@rowIndex].amount_dpp" value="@d.amount_dpp" /></td>
                                        <td>@d.amount_vat <input type="hidden" name="Details[@rowIndex].amount_vat" value="@d.amount_vat" /></td>
                                        <td>@d.amount_freight <input type="hidden" name="Details[@rowIndex].amount_freight" value="@d.amount_freight" /></td>
                                        <td>@d.amount_freight_vat <input type="hidden" name="Details[@rowIndex].amount_freight_vat" value="@d.amount_freight_vat" /></td>
                                        <td>@d.remarks_item <input type="hidden" name="Details[@rowIndex].remarks_item" value="@d.remarks_item" /></td>
                                        @if (!readOnly)
                                        {
                                            <td>
                                                <button type="button" class="btn btn-sm btn-primary btn-edit-detail"><i class="fas fa-edit"></i></button>
                                                <button type="button" class="btn btn-sm btn-danger btn-remove-detail"><i class="fas fa-trash"></i></button>
                                            </td>
                                        }
                                    </tr>
                                    rowIndex++;
                                }
                            }
                            else
                            {
                            <tr id="emptyDetailRow">
                                <td colspan="@(readOnly ? 10 : 11)" class="text-center text-muted">No detail added</td>
                            </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="row mt-3">
            <div class="col-12 mb-4">
                <div style="display: flex; justify-content: flex-start; gap:10px;">
                    <a href="@Url.Action("Index", "Operational")" class="btn btn-secondary">Cancel</a>
                    @if (mode == "Create")
                    {
                        <input type="submit" value="Create Transaction" class="btn btn-success">
                    }
                    else if (mode == "Edit")
                    {
                        <input type="submit" value="Save" class="btn btn-success">
                    }
                    else if (mode == "Delete")
                    {
                        <input type="submit" value="Delete" class="btn btn-danger">
                    }
                </div>
            </div>
        </div>
    }
</section>

<!-- ========== Modal Add/Edit Detail ========== -->
<div class="modal fade" id="detailModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="detailModalTitle">Add Detail</h5>
                <button type="button" class="close" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="detailEditIndex" value="-1" />

                <div class="form-group row">
                    <label class="col-sm-4 col-form-label">PO No <span class="text-danger">*</span></label>
                    <div class="col-sm-8">
                        <input type="text" class="form-control" id="modal_po_no" placeholder="Input Nomor PO" />
                    </div>
                </div>

                <div class="form-group row">
                    <label class="col-sm-4 col-form-label">PO Type <span class="text-danger">*</span></label>
                    <div class="col-sm-8">
                        <select class="form-control" id="modal_po_type">
                            <option value="">-- Select PO Type --</option>
                            @if (Model.PoTypeList != null)
                            {
                                foreach (var pt in Model.PoTypeList.Where(p => p.deleted != true))
                                {
                                    <option value="@pt.type_code">@pt.type_desc</option>
                                }
                            }
                        </select>
                    </div>
                </div>

                <div class="form-group row">
                    <label class="col-sm-4 col-form-label">PO Date <span class="text-danger">*</span></label>
                    <div class="col-sm-8">
                        <input type="date" class="form-control" id="modal_po_date" />
                    </div>
                </div>

                <div class="form-group row">
                    <label class="col-sm-4 col-form-label">Department <span class="text-danger">*</span></label>
                    <div class="col-sm-8">
                        <select class="form-control" id="modal_po_dept">
                            <option value="">-- Select Department --</option>
                            @if (Model.DepartmentList != null)
                            {
                                foreach (var d in Model.DepartmentList.Where(x => x.deleted != true))
                                {
                                    <option value="@d.department_code">@d.department_code</option>
                                }
                            }
                        </select>
                    </div>
                </div>

                <div class="form-group row">
                    <label class="col-sm-4 col-form-label">Amount DPP</label>
                    <div class="col-sm-8">
                        <input type="number" class="form-control" id="modal_amount_dpp" />
                    </div>
                </div>

                <div class="form-group row">
                    <label class="col-sm-4 col-form-label">Amount VAT</label>
                    <div class="col-sm-8">
                        <input type="number" class="form-control" id="modal_amount_vat" />
                    </div>
                </div>

                <div class="form-group row">
                    <label class="col-sm-4 col-form-label">Amount Freight</label>
                    <div class="col-sm-8">
                        <input type="number" class="form-control" id="modal_amount_freight" />
                    </div>
                </div>

                <div class="form-group row">
                    <label class="col-sm-4 col-form-label">Amount Freight VAT</label>
                    <div class="col-sm-8">
                        <input type="number" class="form-control" id="modal_amount_freight_vat" />
                    </div>
                </div>

                <div class="form-group row">
                    <label class="col-sm-4 col-form-label">Remarks</label>
                    <div class="col-sm-8">
                        <textarea class="form-control" id="modal_remarks_item" rows="3" placeholder="Input Remarks"></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="btnSaveDetail">Add</button>
            </div>
        </div>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<script>
    $(document).ready(function () {
        var mode = '@mode';
        var oldStatus = '@((ViewBag.CurrentStatus as string) ?? "")';

        // Toastr config
        if (typeof toastr !== 'undefined') {
            toastr.options = {
                "closeButton": true,
                "progressBar": true,
                "positionClass": "toast-top-right",
                "timeOut": "3000"
            };
        }

        function showNotification(message, type) {
            if (typeof toastr !== 'undefined') {
                if (type === 'success') toastr.success(message);
                else if (type === 'error') toastr.error(message);
                else toastr.info(message);
            } else {
                alert(message);
            }
        }

        // Select2 init
        if ($.fn.select2) {
            $('.select2').select2({ width: '100%' });
        } else {
            console.warn('Select2 not loaded, skip init');
        }

        // DETAIL TABLE HANDLING
        function reindexDetails() {
            $('#detailTableBody tr[data-index]').each(function (i) {
                $(this).attr('data-index', i);
                $(this).find('td:first').text(i + 1);
                $(this).find('input[type="hidden"]').each(function () {
                    var name = $(this).attr('name');
                    if (name) {
                        // Ganti Details[N].field → Details[i].field
                        var newName = name.replace(/Details\[\d+\]/, 'Details[' + i + ']');
                        $(this).attr('name', newName);
                    }
                });
            });

            // Tampilkan/sembunyikan empty row
            if ($('#detailTableBody tr[data-index]').length === 0) {
                if ($('#emptyDetailRow').length === 0) {
                    var colspan = @(readOnly ? 10 : 11);
                    $('#detailTableBody').html('<tr id="emptyDetailRow"><td colspan="' + colspan + '" class="text-center text-muted">No detail added</td></tr>');
                }
            } else {
                $('#emptyDetailRow').remove();
            }
        }

        // Tombol "Add Detail" - buka modal
        $('#btnAddDetail').on('click', function () {
            $('#detailModalTitle').text('Add Detail');
            $('#btnSaveDetail').text('Add');
            $('#detailEditIndex').val('-1');

            // Reset form modal
            $('#modal_po_no').val('');
            $('#modal_po_type').val('');
            $('#modal_po_date').val('');
            $('#modal_po_dept').val('');
            $('#modal_amount_dpp').val('');
            $('#modal_amount_vat').val('');
            $('#modal_amount_freight').val('');
            $('#modal_amount_freight_vat').val('');
            $('#modal_remarks_item').val('');  

            $('#detailModal').modal('show');
        });

        // Tombol "Save" di modal (Add atau Edit)
        $('#btnSaveDetail').on('click', function () {
            var po_no = $('#modal_po_no').val();
            var po_type = $('#modal_po_type').val();
            var po_date = $('#modal_po_date').val();
            var po_dept = $('#modal_po_dept').val();
            var amount_dpp = $('#modal_amount_dpp').val();
            var amount_vat = $('#modal_amount_vat').val();
            var amount_freight = $('#modal_amount_freight').val();
            var amount_freight_vat = $('#modal_amount_freight_vat').val();
            var remarks_item = $('#modal_remarks_item').val(); 

            // Validasi required
            if (!po_no || !po_type || !po_date || !po_dept) {
                showNotification('PO No, PO Type, PO Date, and Department are required', 'error');
                return;
            }

            var editIndex = parseInt($('#detailEditIndex').val());

            if (editIndex >= 0) {
                // Edit mode: update baris yang ada
                var $row = $('#detailTableBody tr[data-index="' + editIndex + '"]');
                $row.find('td').eq(1).html(po_no + '<input type="hidden" name="Details[' + editIndex + '].po_no" value="' + po_no + '" />');
                $row.find('td').eq(2).html(po_type + '<input type="hidden" name="Details[' + editIndex + '].po_type" value="' + po_type + '" />');
                $row.find('td').eq(3).html(po_date + '<input type="hidden" name="Details[' + editIndex + '].po_date" value="' + po_date + '" />');
                $row.find('td').eq(4).html(po_dept + '<input type="hidden" name="Details[' + editIndex + '].po_dept" value="' + po_dept + '" />');
                $row.find('td').eq(5).html((amount_dpp || '') + '<input type="hidden" name="Details[' + editIndex + '].amount_dpp" value="' + (amount_dpp || '') + '" />');
                $row.find('td').eq(6).html((amount_vat || '') + '<input type="hidden" name="Details[' + editIndex + '].amount_vat" value="' + (amount_vat || '') + '" />');
                $row.find('td').eq(7).html((amount_freight || '') + '<input type="hidden" name="Details[' + editIndex + '].amount_freight" value="' + (amount_freight || '') + '" />');
                $row.find('td').eq(8).html((amount_freight_vat || '') + '<input type="hidden" name="Details[' + editIndex + '].amount_freight_vat" value="' + (amount_freight_vat || '') + '" />');
                $row.find('td').eq(9).html((remarks_item || '') + '<input type="hidden" name="Details[' + editIndex + '].remarks_item" value="' + (remarks_item || '') + '" />');
            } else {
                // Add mode: tambah baris baru
                $('#emptyDetailRow').remove();

                var newIndex = $('#detailTableBody tr[data-index]').length;
                var rowHtml = '<tr data-index="' + newIndex + '">' +
                    '<td>' + (newIndex + 1) + '</td>' +
                    '<td>' + po_no + '<input type="hidden" name="Details[' + newIndex + '].po_no" value="' + po_no + '" /></td>' +
                    '<td>' + po_type + '<input type="hidden" name="Details[' + newIndex + '].po_type" value="' + po_type + '" /></td>' +
                    '<td>' + po_date + '<input type="hidden" name="Details[' + newIndex + '].po_date" value="' + po_date + '" /></td>' +
                    '<td>' + po_dept + '<input type="hidden" name="Details[' + newIndex + '].po_dept" value="' + po_dept + '" /></td>' +
                    '<td>' + (amount_dpp || '') + '<input type="hidden" name="Details[' + newIndex + '].amount_dpp" value="' + (amount_dpp || '') + '" /></td>' +
                    '<td>' + (amount_vat || '') + '<input type="hidden" name="Details[' + newIndex + '].amount_vat" value="' + (amount_vat || '') + '" /></td>' +
                    '<td>' + (amount_freight || '') + '<input type="hidden" name="Details[' + newIndex + '].amount_freight" value="' + (amount_freight || '') + '" /></td>' +
                    '<td>' + (amount_freight_vat || '') + '<input type="hidden" name="Details[' + newIndex + '].amount_freight_vat" value="' + (amount_freight_vat || '') + '" /></td>' +
                    '<td>' + (remarks_item || '') + '<input type="hidden" name="Details[' + newIndex + '].remarks_item" value="' + (remarks_item || '') + '" /></td>' +   // ← TAMBAHKAN BARIS INI
                    '<td>' +
                    '<button type="button" class="btn btn-sm btn-primary btn-edit-detail"><i class="fas fa-edit"></i></button> ' +
                    '<button type="button" class="btn btn-sm btn-danger btn-remove-detail"><i class="fas fa-trash"></i></button>' +
                    '</td>' +
                    '</tr>';
                $('#detailTableBody').append(rowHtml);
            }

            $('#detailModal').modal('hide');
        });

        // Tombol Edit di baris tabel
        $('#detailTableBody').on('click', '.btn-edit-detail', function () {
            var $row = $(this).closest('tr');
            var index = $row.attr('data-index');

            // Load data dari hidden fields ke modal
            $('#modal_po_no').val($row.find('input[name$=".po_no"]').val());
            $('#modal_po_type').val($row.find('input[name$=".po_type"]').val());
            $('#modal_po_date').val($row.find('input[name$=".po_date"]').val());
            $('#modal_po_dept').val($row.find('input[name$=".po_dept"]').val());
            $('#modal_amount_dpp').val($row.find('input[name$=".amount_dpp"]').val());
            $('#modal_amount_vat').val($row.find('input[name$=".amount_vat"]').val());
            $('#modal_amount_freight').val($row.find('input[name$=".amount_freight"]').val());
            $('#modal_amount_freight_vat').val($row.find('input[name$=".amount_freight_vat"]').val());
            $('#modal_remarks_item').val($row.find('input[name$=".remarks_item"]').val());

            $('#detailEditIndex').val(index);
            $('#detailModalTitle').text('Edit Detail');
            $('#btnSaveDetail').text('Update');
            $('#detailModal').modal('show');
        });

        // Tombol Remove di baris tabel
        $('#detailTableBody').on('click', '.btn-remove-detail', function () {
            if (!confirm('Remove this detail?')) return;
            $(this).closest('tr').remove();
            reindexDetails();
        });

        // Main form submit
        $('#operationalForm').on('submit', function (e) {
            e.preventDefault();
            var newStatus = ($('[name="status_value"]').val() || '').toString().trim();

            if (mode === 'Delete') {
                if (!confirm('Are you sure you want to delete this Operational record and all its details?')) {
                    return false;
                }
            }

            $('.is-invalid').removeClass('is-invalid');
            $('.validation-error').remove();

            if (mode !== 'Delete') {
                if (newStatus === 'Send To AP' && oldStatus !== 'Send To AP') {
                    showNotification('Status "Send To AP" hanya bisa diubah lewat tombol di halaman Index. Silakan pilih status lain.', 'error');
                    return false;
                }
                // =============================================

                if (!validateForm()) {
                    showNotification('Please fill in all required fields.', 'error');
                    return false;
                }
            }

            var $submitBtn = $(this).find('input[type="submit"]');
            var originalText = $submitBtn.val();
            $submitBtn.val('Processing...').prop('disabled', true);

            $.ajax({
                url: $(this).attr('action'),
                type: 'POST',
                data: $(this).serialize(),
                success: function (response) {
                    if (response && response.success) {
                        showNotification(response.message || 'Operation successful', 'success');
                        setTimeout(function () {
                            window.location.href = '@Url.Action("Index", "Operational")';
                        }, 800);
                    } else {
                        var msg = (response && response.message) ? response.message : 'An error occurred';
                        showNotification(msg, 'error');
                        if (response && response.errors) {
                            showServerErrors(response.errors);
                        }
                        $submitBtn.val(originalText).prop('disabled', false);
                    }
                },
                error: function (xhr) {
                    console.error('AJAX error:', xhr.responseText);
                    showNotification('Server error. Please try again.', 'error');
                    $submitBtn.val(originalText).prop('disabled', false);
                }
            });
        });

        function validateForm() {
            var isValid = true;

            var requiredFields = [
                { name: 'company_code', label: 'Company Code', isSelect: true },
                { name: 'currency', label: 'Currency', isSelect: true },
                { name: 'currency_rate', label: 'Currency Rate' },
                { name: 'vendor', label: 'Vendor', isSelect: true },
                { name: 'status_value', label: 'Status', isSelect: true }
            ];

            requiredFields.forEach(function (field) {
                var $el = $('[name="' + field.name + '"]');
                var val = $el.val();

                if (!val || val.toString().trim() === '') {
                    markError($el, field.isSelect, field.label + ' is required');
                    isValid = false;
                }
            });

            return isValid;
        }

        function markError($el, isSelect, message) {
            if (isSelect) {
                $el.next('.select2-container').addClass('is-invalid');
                $el.after('<span class="text-danger validation-error d-block mt-1" style="font-size: 0.85em;">' + message + '</span>');
            } else {
                $el.addClass('is-invalid');
                $el.after('<span class="text-danger validation-error d-block mt-1" style="font-size: 0.85em;">' + message + '</span>');
            }
        }

        function showServerErrors(errors) {
            $.each(errors, function (key, messages) {
                var $el = $('[name="' + key + '"]').first();
                if ($el.length === 0) $el = $('#' + key).first();
                if ($el.length) {
                    var isSelect = $el.is('select');
                    markError($el, isSelect, messages.join(', '));
                }
            });
        }
    });
</script>